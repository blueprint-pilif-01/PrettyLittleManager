# Public DNS name whose A/AAAA record points to this VPS. Caddy obtains HTTPS automatically.
APP_HOST=plm.example.ro
ACME_EMAIL=admin@example.ro

POSTGRES_DB=pretty_little_manager
POSTGRES_USER=plm
# Use URL-safe random values (letters, digits, hyphen, underscore) because Compose
# also interpolates these passwords into DATABASE_URL and REDIS_URL.
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
REDIS_PASSWORD=replace-with-a-long-random-redis-password

MINIO_ROOT_USER=plm_storage
MINIO_ROOT_PASSWORD=replace-with-a-long-random-storage-password
OBJECT_STORAGE_BUCKET=plm-media
OBJECT_STORAGE_REGION=eu-central-1

# At least 32 random characters. Remove INITIAL_SETUP_TOKEN after the first admin is created.
SESSION_SECRET=replace-with-at-least-32-random-characters
INITIAL_SETUP_TOKEN=replace-with-a-one-time-32-plus-character-token
# Exactly 32 random bytes encoded as base64, or 64 hexadecimal characters.
ENCRYPTION_KEY=replace-with-a-32-byte-key

WORKSPACE_SLUG=aline
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
WORKER_CONCURRENCY=5

EMAG_MODE=mock
EMAG_MARKETPLACE=EMAG_RO
EMAG_API_URL=https://marketplace-api.emag.ro/api-3
EMAG_USERNAME=
EMAG_PASSWORD=
EMAG_TIMEOUT_MS=15000
EMAG_MAX_RETRIES=4

BACKUP_RETENTION_DAYS=14
