generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  READY
  ACTIVE
  ARCHIVED
}

enum ProductType {
  SIMPLE
  PARENT
  BUNDLE
}

enum AttributeDataType {
  SHORT_TEXT
  LONG_TEXT
  RICH_TEXT
  INTEGER
  DECIMAL
  BOOLEAN
  DATE
  DATETIME
  SINGLE_SELECT
  MULTI_SELECT
  COLOR
  MEASUREMENT
  FILE
  IMAGE
  URL
  EMAIL
  JSON
}

enum AttributeScope {
  PRODUCT
  VARIANT
}

enum ImageProcessingStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum ProductImageRole {
  MAIN
  SECONDARY
  OTHER
}

enum Gs1RegistrationStatus {
  NOT_STARTED
  DRAFT
  READY_FOR_REGISTRATION
  SUBMITTED_MANUALLY
  GTIN_ASSIGNED
  VALIDATION_FAILED
  ACTIVE
  INACTIVE
}

enum GtinType {
  GTIN_8
  GTIN_12
  GTIN_13
  GTIN_14
}

enum GtinAssignmentSource {
  MANUAL_GS1
  IMPORTED
  LEGACY
}

enum ChannelType {
  EMAG
  WEBSITE
}

enum EmagPublicationPath {
  NEW_PRODUCT
  ATTACH_EXISTING
  UPDATE_OFFER
}

enum NotificationSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum ListingStatus {
  DRAFT
  VALIDATION_FAILED
  QUEUED
  PUBLISHED
  PAUSED
  FAILED
}

enum SynchronizationStatus {
  NOT_SYNCED
  QUEUED
  IN_PROGRESS
  SYNCED
  FAILED
  PARTIALLY_SYNCED
  RECONCILIATION_REQUIRED
}

enum InventoryMovementType {
  INITIAL
  RECEIPT
  SALE_RESERVATION
  RESERVATION_RELEASE
  SALE_COMPLETION
  RETURN_RECEIPT
  MANUAL_INCREASE
  MANUAL_DECREASE
  DAMAGED
  QUARANTINED
  CORRECTION
  STOCK_COUNT
  // Legacy names retained so existing ledgers remain readable.
  ADJUSTMENT
  RESERVATION
  RELEASE
  SALE
  RETURN
  TRANSFER_IN
  TRANSFER_OUT
}

enum InventoryReservationStatus {
  ACTIVE
  RELEASED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum InventoryTransferStatus {
  COMPLETED
  CANCELLED
}

enum StockCountStatus {
  DRAFT
  APPLIED
  CANCELLED
}

enum FileFormat {
  XLS
  XLSX
  CSV
}

enum ImportJobStatus {
  UPLOADED
  MAPPING
  VALIDATED
  QUEUED
  RUNNING
  PARTIALLY_SUCCEEDED
  SUCCEEDED
  FAILED
  CANCELLED
}

enum ImportRowStatus {
  VALID
  WARNING
  BLOCKED
  IMPORTED
  FAILED
  SKIPPED
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  PARTIALLY_SUCCEEDED
  FAILED
  CANCELLED
}

model Company {
  id                     String                  @id @default(uuid()) @db.Uuid
  name                   String
  slug                   String                  @unique
  settings               Json                    @default("{}")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  memberships            Membership[]
  roles                  Role[]
  invitations            Invitation[]
  productFamilies        ProductFamily[]
  products               Product[]
  productVariants        ProductVariant[]
  brands                 Brand[]
  attributeDefinitions   AttributeDefinition[]
  productImages          ProductImage[]
  gtinAssignments        GtinAssignment[]
  categories             Category[]
  warehouses             Warehouse[]
  warehouseLocations     WarehouseLocation[]
  inventoryMovements     InventoryMovement[]
  inventoryReservations  InventoryReservation[]
  inventoryTransfers     InventoryTransfer[]
  inventoryStockCounts   InventoryStockCount[]
  importMappingTemplates ImportMappingTemplate[]
  importJobs             ImportJob[]
  exportTemplates        ExportTemplate[]
  exportJobs             ExportJob[]
  channelAccounts        ChannelAccount[]
  channelListings        ChannelListing[]
  websiteApiCredentials  WebsiteApiCredential[]
  categoryMappings       CategoryMapping[]
  emagCategories         EmagCategory[]
  emagCharacteristics    EmagCharacteristic[]
  emagFamilyTypes        EmagFamilyType[]
  emagVatRates           EmagVatRate[]
  emagHandlingTimes      EmagHandlingTime[]
  integrationRequestLogs IntegrationRequestLog[]
  notifications          Notification[]
  auditLogs              AuditLog[]
  jobs                   BackgroundJob[]
}

model User {
  id                     String                  @id @default(uuid()) @db.Uuid
  email                  String                  @unique
  displayName            String
  passwordHash           String?
  status                 UserStatus              @default(INVITED)
  lastLoginAt            DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  memberships            Membership[]
  sessions               UserSession[]
  passwordResetTokens    PasswordResetToken[]
  invitationsSent        Invitation[]            @relation("InvitationSender")
  auditLogs              AuditLog[]              @relation("ActorAuditLogs")
  productsCreated        Product[]               @relation("ProductCreatedBy")
  productsUpdated        Product[]               @relation("ProductUpdatedBy")
  variantsCreated        ProductVariant[]        @relation("VariantCreatedBy")
  variantsUpdated        ProductVariant[]        @relation("VariantUpdatedBy")
  imagesCreated          ProductImage[]          @relation("ImageCreatedBy")
  gtinsCreated           GtinAssignment[]        @relation("GtinCreatedBy")
  inventoryMovements     InventoryMovement[]     @relation("InventoryMovementActor")
  reservationsCreated    InventoryReservation[]  @relation("InventoryReservationCreator")
  transfersCreated       InventoryTransfer[]     @relation("InventoryTransferCreator")
  stockCountsCreated     InventoryStockCount[]   @relation("InventoryStockCountCreator")
  importMappingsCreated  ImportMappingTemplate[] @relation("ImportMappingCreator")
  importJobsCreated      ImportJob[]             @relation("ImportJobCreator")
  exportTemplatesCreated ExportTemplate[]        @relation("ExportTemplateCreator")
  exportJobsCreated      ExportJob[]             @relation("ExportJobCreator")
  websiteApiKeysCreated  WebsiteApiCredential[]  @relation("WebsiteApiCredentialCreator")
}

model Membership {
  id        String        @id @default(uuid()) @db.Uuid
  companyId String        @db.Uuid
  userId    String        @db.Uuid
  roleId    String        @db.Uuid
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role          @relation(fields: [roleId], references: [id], onDelete: Restrict)
  sessions  UserSession[]

  @@unique([companyId, userId])
  @@index([userId])
  @@index([companyId, roleId])
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  companyId   String           @db.Uuid
  key         String
  name        String
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberships Membership[]
  permissions RolePermission[]
  invitations Invitation[]

  @@unique([companyId, key])
  @@index([companyId, name])
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique
  description String
  roles       RolePermission[]
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserSession {
  id               String     @id @default(uuid()) @db.Uuid
  userId           String     @db.Uuid
  membershipId     String     @db.Uuid
  refreshTokenHash String     @unique
  familyId         String     @db.Uuid
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  lastUsedAt       DateTime   @default(now())
  revokedAt        DateTime?
  revokeReason     String?
  replacedById     String?    @db.Uuid
  createdAt        DateTime   @default(now())
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership       Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
  @@index([membershipId, revokedAt, expiresAt])
  @@index([familyId])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Invitation {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @db.Uuid
  email       String
  roleId      String    @db.Uuid
  tokenHash   String    @unique
  invitedById String    @db.Uuid
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Restrict)
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@index([companyId, email])
  @@index([roleId])
}

model Category {
  id                   String                        @id @default(uuid()) @db.Uuid
  companyId            String                        @db.Uuid
  parentId             String?                       @db.Uuid
  name                 String
  slug                 String
  description          String?
  gs1GpcCode           String?
  isActive             Boolean                       @default(true)
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  company              Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent               Category?                     @relation("CategoryTree", fields: [parentId], references: [id])
  children             Category[]                    @relation("CategoryTree")
  products             Product[]
  attributeDefinitions CategoryAttributeDefinition[]
  channelMappings      CategoryMapping[]

  @@unique([companyId, slug])
  @@index([companyId, parentId])
  @@index([companyId, isActive, name])
}

model Brand {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String    @db.Uuid
  name         String
  slug         String
  manufacturer String?
  websiteUrl   String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([companyId, slug])
  @@index([companyId, name])
}

model AttributeDefinition {
  id            String                        @id @default(uuid()) @db.Uuid
  companyId     String                        @db.Uuid
  key           String
  displayName   String
  description   String?
  dataType      AttributeDataType
  scope         AttributeScope
  isRequired    Boolean                       @default(false)
  defaultValue  Json?
  minimum       Decimal?                      @db.Decimal(18, 6)
  maximum       Decimal?                      @db.Decimal(18, 6)
  regexPattern  String?
  unitType      String?
  isSearchable  Boolean                       @default(false)
  isFilterable  Boolean                       @default(false)
  isComparable  Boolean                       @default(false)
  isInheritable Boolean                       @default(true)
  displayOrder  Int                           @default(0)
  visibility    String                        @default("INTERNAL")
  localization  Json                          @default("{}")
  isActive      Boolean                       @default(true)
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt
  company       Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  options       AttributeOption[]
  categories    CategoryAttributeDefinition[]
  productValues ProductAttributeValue[]
  variantValues VariantAttributeValue[]

  @@unique([companyId, key])
  @@index([companyId, scope, isActive, displayOrder])
  @@index([companyId, isSearchable])
  @@index([companyId, isFilterable])
}

model AttributeOption {
  id                    String              @id @default(uuid()) @db.Uuid
  attributeDefinitionId String              @db.Uuid
  value                 String
  label                 String
  localization          Json                @default("{}")
  displayOrder          Int                 @default(0)
  isActive              Boolean             @default(true)
  definition            AttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Cascade)

  @@unique([attributeDefinitionId, value])
  @@index([attributeDefinitionId, displayOrder])
}

model CategoryAttributeDefinition {
  categoryId            String              @db.Uuid
  attributeDefinitionId String              @db.Uuid
  isRequiredOverride    Boolean?
  displayOrder          Int                 @default(0)
  category              Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  definition            AttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Cascade)

  @@id([categoryId, attributeDefinitionId])
  @@index([attributeDefinitionId])
}

model ProductFamily {
  id              String                @id @default(uuid()) @db.Uuid
  companyId       String                @db.Uuid
  productId       String                @unique @db.Uuid
  sellerFamilyId  Int?
  code            String
  name            String
  description     String?
  variationAxes   Json                  @default("[]")
  status          ProductStatus         @default(DRAFT)
  channelMetadata Json                  @default("{}")
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  company         Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product         Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  members         ProductFamilyMember[]

  @@unique([companyId, code])
  @@unique([companyId, sellerFamilyId])
  @@index([companyId, status, name])
}

model Product {
  id                         String                   @id @default(uuid()) @db.Uuid
  companyId                  String                   @db.Uuid
  parentProductId            String?                  @db.Uuid
  productType                ProductType              @default(SIMPLE)
  status                     ProductStatus            @default(DRAFT)
  internalName               String
  publicName                 String
  shortName                  String?
  slug                       String
  brandId                    String?                  @db.Uuid
  categoryId                 String?                  @db.Uuid
  description                String?
  shortDescription           String?
  gs1LabelDescription        String?
  safetyInformation          String?
  manufacturerPartNumber     String?
  manufacturerName           String?
  manufacturerAddress        String?
  manufacturerEmail          String?
  euResponsiblePersonName    String?
  euResponsiblePersonAddress String?
  euResponsiblePersonEmail   String?
  seoTitle                   String?
  seoDescription             String?
  defaultLanguage            String                   @default("ro")
  taxClass                   String?
  defaultVatRate             Decimal?                 @db.Decimal(5, 2)
  defaultCurrency            String                   @default("RON")
  weight                     Decimal?                 @db.Decimal(12, 3)
  weightUnit                 String?                  @default("G")
  length                     Decimal?                 @db.Decimal(12, 3)
  width                      Decimal?                 @db.Decimal(12, 3)
  height                     Decimal?                 @db.Decimal(12, 3)
  diameter                   Decimal?                 @db.Decimal(12, 3)
  dimensionUnit              String?                  @default("MM")
  createdById                String                   @db.Uuid
  updatedById                String                   @db.Uuid
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  deletedAt                  DateTime?
  company                    Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent                     Product?                 @relation("ProductHierarchy", fields: [parentProductId], references: [id], onDelete: SetNull)
  children                   Product[]                @relation("ProductHierarchy")
  brand                      Brand?                   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category                   Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy                  User                     @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy                  User                     @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  family                     ProductFamily?
  variants                   ProductVariant[]
  attributeValues            ProductAttributeValue[]
  imageAssignments           ProductImageAssignment[]
  listings                   ChannelListing[]

  @@unique([companyId, slug])
  @@index([companyId, status, updatedAt])
  @@index([companyId, productType, status])
  @@index([companyId, categoryId, status])
  @@index([companyId, brandId, status])
  @@index([companyId, parentProductId])
  @@index([companyId, internalName])
  @@index([companyId, publicName])
}

model ProductVariant {
  id                String                   @id @default(uuid()) @db.Uuid
  companyId         String                   @db.Uuid
  productId         String                   @db.Uuid
  sku               String
  internalNumericId Int
  gtin              String?                  @unique
  gtinType          GtinType?
  variantName       String
  status            ProductStatus            @default(DRAFT)
  basePrice         Decimal?                 @db.Decimal(12, 2)
  costPrice         Decimal?                 @db.Decimal(12, 2)
  currency          String                   @default("RON")
  weight            Decimal?                 @db.Decimal(12, 3)
  weightUnit        String?
  length            Decimal?                 @db.Decimal(12, 3)
  width             Decimal?                 @db.Decimal(12, 3)
  height            Decimal?                 @db.Decimal(12, 3)
  diameter          Decimal?                 @db.Decimal(12, 3)
  dimensionUnit     String?
  isDefaultVariant  Boolean                  @default(false)
  variationValues   Json                     @default("{}")
  variationKey      String
  createdById       String                   @db.Uuid
  updatedById       String                   @db.Uuid
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  deletedAt         DateTime?
  company           Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product           Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy         User                     @relation("VariantCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy         User                     @relation("VariantUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  familyMemberships ProductFamilyMember[]
  attributeValues   VariantAttributeValue[]
  imageAssignments  ProductImageAssignment[]
  gs1Registration   Gs1Registration?
  gtinAssignment    GtinAssignment?
  stockLevels       StockLevel[]
  movements         InventoryMovement[]
  reservations      InventoryReservation[]
  transfers         InventoryTransfer[]
  stockCounts       InventoryStockCount[]
  listings          ChannelListing[]

  @@unique([companyId, sku])
  @@unique([companyId, internalNumericId])
  @@unique([productId, variationKey])
  @@index([companyId, status, updatedAt])
  @@index([companyId, productId, status])
  @@index([companyId, gtin])
}

model ProductFamilyMember {
  familyId  String         @db.Uuid
  variantId String         @db.Uuid
  position  Int            @default(0)
  family    ProductFamily  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([familyId, variantId])
  @@unique([variantId])
  @@index([familyId, position])
}

model ProductAttributeValue {
  id                    String              @id @default(uuid()) @db.Uuid
  productId             String              @db.Uuid
  attributeDefinitionId String              @db.Uuid
  locale                String              @default("")
  value                 Json
  isOverride            Boolean             @default(false)
  updatedAt             DateTime            @updatedAt
  product               Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  definition            AttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Restrict)

  @@unique([productId, attributeDefinitionId, locale])
  @@index([attributeDefinitionId])
}

model VariantAttributeValue {
  id                    String              @id @default(uuid()) @db.Uuid
  variantId             String              @db.Uuid
  attributeDefinitionId String              @db.Uuid
  locale                String              @default("")
  value                 Json
  isOverride            Boolean             @default(true)
  updatedAt             DateTime            @updatedAt
  variant               ProductVariant      @relation(fields: [variantId], references: [id], onDelete: Cascade)
  definition            AttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Restrict)

  @@unique([variantId, attributeDefinitionId, locale])
  @@index([attributeDefinitionId])
}

model ProductImage {
  id               String                   @id @default(uuid()) @db.Uuid
  companyId        String                   @db.Uuid
  objectKey        String
  originalFileName String
  mimeType         String
  sizeBytes        Int
  sha256           String
  width            Int?
  height           Int?
  processingStatus ImageProcessingStatus    @default(PENDING)
  publicUrl        String?
  thumbnailUrl     String?
  mediumUrl        String?
  metadata         Json                     @default("{}")
  createdById      String                   @db.Uuid
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  deletedAt        DateTime?
  company          Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy        User                     @relation("ImageCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignments      ProductImageAssignment[]

  @@unique([companyId, objectKey])
  @@unique([companyId, sha256])
  @@index([companyId, processingStatus, createdAt])
}

model ProductImageAssignment {
  id        String           @id @default(uuid()) @db.Uuid
  imageId   String           @db.Uuid
  productId String?          @db.Uuid
  variantId String?          @db.Uuid
  role      ProductImageRole @default(OTHER)
  position  Int              @default(0)
  altText   String?
  image     ProductImage     @relation(fields: [imageId], references: [id], onDelete: Cascade)
  product   Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant?  @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([imageId, productId, variantId])
  @@index([productId, position])
  @@index([variantId, position])
}

model Gs1Registration {
  id                           String                @id @default(uuid()) @db.Uuid
  variantId                    String                @unique @db.Uuid
  status                       Gs1RegistrationStatus @default(NOT_STARTED)
  gtinType                     GtinType              @default(GTIN_13)
  activityDomain               String?
  productName                  String?
  shortProductName             String?
  labelDescription             String?
  isPromotionalProduct         Boolean               @default(false)
  brand                        String?
  internalCode                 String?
  packagingMaterial            String?
  packagingType                String?
  netQuantity                  Decimal?              @db.Decimal(18, 6)
  netQuantityUnit              String?
  targetMarkets                Json                  @default("[]")
  productPresentationUrl       String?
  productImageUrl              String?
  height                       Decimal?              @db.Decimal(12, 3)
  heightUnit                   String?
  width                        Decimal?              @db.Decimal(12, 3)
  widthUnit                    String?
  length                       Decimal?              @db.Decimal(12, 3)
  lengthUnit                   String?
  diameter                     Decimal?              @db.Decimal(12, 3)
  diameterUnit                 String?
  romanianDistributionNetworks Json                  @default("[]")
  otherDistributionNetworks    Json                  @default("[]")
  gpcCode                      String?
  responsibilityConfirmed      Boolean               @default(false)
  submittedAt                  DateTime?
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  variant                      ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model GtinAssignment {
  id          String               @id @default(uuid()) @db.Uuid
  companyId   String               @db.Uuid
  variantId   String               @unique @db.Uuid
  gtin        String               @unique
  gtinType    GtinType
  source      GtinAssignmentSource
  assignedAt  DateTime             @default(now())
  createdById String               @db.Uuid
  createdAt   DateTime             @default(now())
  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  variant     ProductVariant       @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdBy   User                 @relation("GtinCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([companyId, assignedAt])
}

model Warehouse {
  id           String                 @id @default(uuid()) @db.Uuid
  companyId    String                 @db.Uuid
  code         String
  name         String
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  company      Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockLevels  StockLevel[]
  movements    InventoryMovement[]
  locations    WarehouseLocation[]
  reservations InventoryReservation[]
  transfersOut InventoryTransfer[]    @relation("TransferSourceWarehouse")
  transfersIn  InventoryTransfer[]    @relation("TransferDestinationWarehouse")
  stockCounts  InventoryStockCount[]

  @@unique([companyId, code])
}

model WarehouseLocation {
  id           String                 @id @default(uuid()) @db.Uuid
  companyId    String                 @db.Uuid
  warehouseId  String                 @db.Uuid
  code         String
  name         String
  type         String                 @default("SELLABLE")
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  company      Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse    Warehouse              @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  movements    InventoryMovement[]
  reservations InventoryReservation[]

  @@unique([warehouseId, code])
  @@index([companyId, warehouseId, isActive])
}

model StockLevel {
  id          String         @id @default(uuid()) @db.Uuid
  variantId   String         @db.Uuid
