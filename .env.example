NODE_ENV=development
WEB_ORIGIN=http://localhost:5173
API_PORT=3000
DATABASE_URL=postgresql://plm:plm_dev_password@localhost:5432/pretty_little_manager?schema=public
REDIS_URL=redis://localhost:6379
OBJECT_STORAGE_DRIVER=local
LOCAL_MEDIA_DIR=.local/media
API_PUBLIC_URL=http://localhost:3000
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=eu-central-1
OBJECT_STORAGE_BUCKET=plm-media
OBJECT_STORAGE_ACCESS_KEY=plm
OBJECT_STORAGE_SECRET_KEY=plm_dev_password
OBJECT_STORAGE_PUBLIC_URL=http://localhost:9000/plm-media
MAIL_HOST=localhost
MAIL_PORT=1025
SESSION_SECRET=replace-with-at-least-32-random-characters
# Required only until the very first administrator is created; use 32+ random characters.
INITIAL_SETUP_TOKEN=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
# 32 random bytes encoded as base64 (or 64 hexadecimal characters). Never commit the real value.
ENCRYPTION_KEY=
WORKSPACE_SLUG=aline
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-temporary-password
EMAG_MODE=mock
EMAG_MARKETPLACE=EMAG_RO
EMAG_API_URL=https://marketplace-api.emag.ro/api-3
EMAG_USERNAME=
EMAG_PASSWORD=
EMAG_TIMEOUT_MS=15000
EMAG_MAX_RETRIES=4
WORKER_CONCURRENCY=5
